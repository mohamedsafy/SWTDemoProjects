sequenceDiagram
autonumber
actor Receptionist
participant HospitalConsole
participant HospitalService
participant HospitalRepository
participant HospitalJson as hospital.json

== System Initialization ==
HospitalConsole->>HospitalService: initialize(repository)
HospitalService->>HospitalRepository: loadPatients()
alt hospital.json exists
  HospitalRepository->>HospitalJson: read patients array
  HospitalJson-->>HospitalRepository: patient records
  HospitalRepository-->>HospitalService: patients
else file missing
  HospitalRepository-->>HospitalService: empty patient list
end
HospitalService->>HospitalRepository: loadAppointments()
alt hospital.json exists
  HospitalRepository->>HospitalJson: read appointments array
  HospitalJson-->>HospitalRepository: appointment records
  HospitalRepository-->>HospitalService: appointments
else file missing
  HospitalRepository-->>HospitalService: empty appointment list
end
HospitalService-->>HospitalConsole: ready with in-memory state

== Register Patient ==
Receptionist->>HospitalConsole: Select "Register Patient"
HospitalConsole->>Receptionist: Prompt for name and age
Receptionist-->>HospitalConsole: name, age
HospitalConsole->>HospitalService: registerPatient(name, age, repository)
HospitalService->>HospitalService: validatePatientInput(name, age)
HospitalService->>HospitalService: assign unique patient ID
HospitalService->>HospitalRepository: saveAll(patients, appointments)
HospitalRepository->>HospitalJson: write updated JSON
HospitalJson-->>HospitalRepository: persisted
HospitalRepository-->>HospitalService: save complete
HospitalService-->>HospitalConsole: created Patient
HospitalConsole-->>Receptionist: Display patient ID and success

== Schedule Appointment ==
Receptionist->>HospitalConsole: Select "Schedule Appointment"
HospitalConsole->>Receptionist: Prompt for patient ID, date, time
Receptionist-->>HospitalConsole: patientId, date, time
HospitalConsole->>HospitalService: scheduleAppointment(patientId, date, time, repository)
HospitalService->>HospitalService: patientExists(patientId)
HospitalService->>HospitalService: validateAppointmentInput(date, time)
HospitalService->>HospitalService: isTimeSlotAvailable(date, time)
alt valid patient and slot available
  HospitalService->>HospitalService: assign unique appointment ID
  HospitalService->>HospitalRepository: saveAll(patients, appointments)
  HospitalRepository->>HospitalJson: write updated JSON
  HospitalJson-->>HospitalRepository: persisted
  HospitalRepository-->>HospitalService: save complete
  HospitalService-->>HospitalConsole: created Appointment
  HospitalConsole-->>Receptionist: Display appointment ID and success
else invalid patient ID or overlapping slot
  HospitalService-->>HospitalConsole: validation failure
  HospitalConsole-->>Receptionist: Display error message
end

== View Patient Records ==
Receptionist->>HospitalConsole: Select "View Patient Records"
HospitalConsole->>HospitalService: getPatients()
HospitalService-->>HospitalConsole: patients
loop for each patient shown
  HospitalConsole->>HospitalService: getAppointmentsForPatient(patientId)
  HospitalService-->>HospitalConsole: associated appointments
end
HospitalConsole-->>Receptionist: Display patients with optional appointments

== Update Patient Information ==
Receptionist->>HospitalConsole: Select "Update Patient Information"
HospitalConsole->>Receptionist: Prompt for patient ID and updated data
Receptionist-->>HospitalConsole: patientId, name, age
HospitalConsole->>HospitalService: updatePatient(patientId, name, age, repository)
HospitalService->>HospitalService: patientExists(patientId)
HospitalService->>HospitalService: validatePatientInput(name, age)
alt patient found and data valid
  HospitalService->>HospitalRepository: saveAll(patients, appointments)
  HospitalRepository->>HospitalJson: write updated JSON
  HospitalJson-->>HospitalRepository: persisted
  HospitalRepository-->>HospitalService: save complete
  HospitalService-->>HospitalConsole: update success
  HospitalConsole-->>Receptionist: Display success
else invalid patient ID or invalid data
  HospitalService-->>HospitalConsole: update failure
  HospitalConsole-->>Receptionist: Display error message
end

== Cancel Appointment ==
Receptionist->>HospitalConsole: Select "Cancel Appointment"
HospitalConsole->>Receptionist: Prompt for appointment ID
Receptionist-->>HospitalConsole: appointmentId
HospitalConsole->>HospitalService: cancelAppointment(appointmentId, repository)
HospitalService->>HospitalService: appointmentExists(appointmentId)
alt appointment found
  HospitalService->>HospitalRepository: saveAll(patients, appointments)
  HospitalRepository->>HospitalJson: write updated JSON
  HospitalJson-->>HospitalRepository: persisted
  HospitalRepository-->>HospitalService: save complete
  HospitalService-->>HospitalConsole: cancellation success
  HospitalConsole-->>Receptionist: Display success
else invalid appointment ID
  HospitalService-->>HospitalConsole: cancellation failure
  HospitalConsole-->>Receptionist: Display error message
end
