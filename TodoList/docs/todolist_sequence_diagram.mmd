sequenceDiagram
autonumber
actor User
participant TodoConsole
participant InputValidator
participant TaskService
participant TaskRepository
participant TasksJson as tasks.json

== System Initialization ==
TodoConsole->>TaskService: initialize()
TaskService->>TaskRepository: loadTasks()
alt tasks.json exists
  TaskRepository->>TasksJson: read tasks array
  TasksJson-->>TaskRepository: persisted task records
  TaskRepository-->>TaskService: vector<Task>
  TaskService->>TaskService: calculateNextId()
else file missing
  TaskRepository-->>TaskService: empty task list
  TaskService->>TaskService: set nextId = 1
end
TaskService-->>TodoConsole: ready
TodoConsole-->>User: display main menu

== Add Task ==
User->>TodoConsole: Select "Add Task"
TodoConsole->>User: Prompt for description
User-->>TodoConsole: description
TodoConsole->>InputValidator: isValidDescription(description)
alt valid description
  TodoConsole->>TaskService: addTask(description)
  TaskService->>TaskService: create Task(nextId, description, false)
  TaskService->>TaskRepository: saveTasks(tasks)
  TaskRepository->>TasksJson: write updated tasks
  TasksJson-->>TaskRepository: persisted
  TaskRepository-->>TaskService: save complete
  TaskService-->>TodoConsole: created Task
  TodoConsole-->>User: display success
else invalid description
  InputValidator-->>TodoConsole: false
  TodoConsole-->>User: display validation error
end

== View Tasks ==
User->>TodoConsole: Select "View Tasks"
TodoConsole->>TaskService: getTasks()
TaskService-->>TodoConsole: vector<Task>
TodoConsole-->>User: display ID, description, completion status

== Complete Task ==
User->>TodoConsole: Select "Complete Task"
TodoConsole->>User: Prompt for task ID
User-->>TodoConsole: taskId
TodoConsole->>InputValidator: isValidTaskId(taskId)
alt valid input
  TodoConsole->>TaskService: completeTask(taskId)
  TaskService->>TaskService: findTaskById(taskId)
  alt task found
    TaskService->>Task: markCompleted()
    TaskService->>TaskRepository: saveTasks(tasks)
    TaskRepository->>TasksJson: write updated tasks
    TasksJson-->>TaskRepository: persisted
    TaskRepository-->>TaskService: save complete
    TaskService-->>TodoConsole: true
    TodoConsole-->>User: display success
  else task not found
    TaskService-->>TodoConsole: false
    TodoConsole-->>User: display invalid ID error
  end
else invalid input
  InputValidator-->>TodoConsole: false
  TodoConsole-->>User: display validation error
end

== Edit Task ==
User->>TodoConsole: Select "Edit Task"
TodoConsole->>User: Prompt for task ID and new description
User-->>TodoConsole: taskId, newDescription
TodoConsole->>InputValidator: isValidTaskId(taskId)
TodoConsole->>InputValidator: isValidDescription(newDescription)
alt valid input
  TodoConsole->>TaskService: editTask(taskId, newDescription)
  TaskService->>TaskService: findTaskById(taskId)
  alt task found
    TaskService->>Task: updateDescription(newDescription)
    TaskService->>TaskRepository: saveTasks(tasks)
    TaskRepository->>TasksJson: write updated tasks
    TasksJson-->>TaskRepository: persisted
    TaskRepository-->>TaskService: save complete
    TaskService-->>TodoConsole: true
    TodoConsole-->>User: display success
  else task not found
    TaskService-->>TodoConsole: false
    TodoConsole-->>User: display invalid ID error
  end
else invalid input
  InputValidator-->>TodoConsole: false
  TodoConsole-->>User: display validation error
end

== Delete Task ==
User->>TodoConsole: Select "Delete Task"
TodoConsole->>User: Prompt for task ID
User-->>TodoConsole: taskId
TodoConsole->>InputValidator: isValidTaskId(taskId)
alt valid input
  TodoConsole->>TaskService: deleteTask(taskId)
  TaskService->>TaskService: findTaskById(taskId)
  alt task found
    TaskService->>TaskService: remove task from vector
    TaskService->>TaskRepository: saveTasks(tasks)
    TaskRepository->>TasksJson: write updated tasks
    TasksJson-->>TaskRepository: persisted
    TaskRepository-->>TaskService: save complete
    TaskService-->>TodoConsole: true
    TodoConsole-->>User: display success
  else task not found
    TaskService-->>TodoConsole: false
    TodoConsole-->>User: display invalid ID error
  end
else invalid input
  InputValidator-->>TodoConsole: false
  TodoConsole-->>User: display validation error
end

== Exit ==
User->>TodoConsole: Select "Exit"
TodoConsole-->>User: terminate application
