sequenceDiagram
participant UI as SchedulerConsole
participant Service as SchedulerService
participant Repo as AppointmentRepository
participant Utils

UI->>UI: handleBook()
UI->>Service: bookAppointment(title, date, time)

Service->>Utils: isValidDate(date)
Service->>Utils: isValidTime(time)

alt Invalid input
    Service-->>UI: failure
else Valid input
    Service->>Repo: getAll()
    Repo-->>Service: appointments

    Service->>Service: check availability

    alt Slot available
        Service->>Service: generateId()
        Service->>Service: create Appointment
        Service->>Repo: add(appointment)
        Service->>Repo: save()
        Service-->>UI: success
    else Slot not available
        Service-->>UI: failure
    end
end
