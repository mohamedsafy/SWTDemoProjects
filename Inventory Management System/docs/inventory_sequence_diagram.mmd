sequenceDiagram
autonumber
actor StoreManager
participant InventoryConsole
participant InventoryService
participant Utils
participant InventoryRepository
participant InventoryJson as inventory.json

== System Initialization ==
InventoryConsole->>InventoryRepository: loadProducts()
alt inventory.json exists
  InventoryRepository->>InventoryJson: read products array
  InventoryJson-->>InventoryRepository: product records
  InventoryRepository-->>InventoryConsole: loadedProducts
else file missing
  InventoryRepository-->>InventoryConsole: empty product list
end
InventoryConsole->>InventoryService: initialize(loadedProducts)
InventoryService->>InventoryService: recalculateNextProductId()
InventoryService-->>InventoryConsole: ready

== Add Product ==
StoreManager->>InventoryConsole: Select "Add Product"
InventoryConsole->>StoreManager: Prompt for name and quantity
StoreManager-->>InventoryConsole: name, quantity
InventoryConsole->>InventoryService: addProduct(name, quantity)
InventoryService->>Utils: isNonEmptyText(name)
InventoryService->>Utils: isNonNegativeQuantity(quantity)
alt valid product data
  InventoryService->>InventoryService: generateNextProductId()
  InventoryService->>InventoryService: append Product
  InventoryService-->>InventoryConsole: created Product
  InventoryConsole->>InventoryService: getAllProducts()
  InventoryService-->>InventoryConsole: products
  InventoryConsole->>InventoryRepository: saveProducts(products)
  InventoryRepository->>InventoryJson: write updated products array
  InventoryJson-->>InventoryRepository: persisted
  InventoryRepository-->>InventoryConsole: save complete
  InventoryConsole-->>StoreManager: Display success and product ID
else invalid name or negative quantity
  InventoryService-->>InventoryConsole: validation failure
  InventoryConsole-->>StoreManager: Display error message
end

== View Inventory ==
StoreManager->>InventoryConsole: Select "View Inventory"
InventoryConsole->>InventoryService: getAllProducts()
InventoryService-->>InventoryConsole: products
InventoryConsole-->>StoreManager: Display all products with ID, name, quantity

== Update Product Quantity ==
StoreManager->>InventoryConsole: Select "Update Product Quantity"
InventoryConsole->>StoreManager: Prompt for product ID and new quantity
StoreManager-->>InventoryConsole: productId, newQuantity
InventoryConsole->>InventoryService: updateProductQuantity(productId, newQuantity)
InventoryService->>Utils: isPositiveId(productId)
InventoryService->>Utils: isNonNegativeQuantity(newQuantity)
InventoryService->>InventoryService: productExists(productId)
alt valid ID and quantity
  InventoryService->>InventoryService: update quantity
  InventoryService-->>InventoryConsole: update success
  InventoryConsole->>InventoryService: getAllProducts()
  InventoryService-->>InventoryConsole: products
  InventoryConsole->>InventoryRepository: saveProducts(products)
  InventoryRepository->>InventoryJson: write updated products array
  InventoryJson-->>InventoryRepository: persisted
  InventoryRepository-->>InventoryConsole: save complete
  InventoryConsole-->>StoreManager: Display success
else invalid ID or negative quantity
  InventoryService-->>InventoryConsole: update failure
  InventoryConsole-->>StoreManager: Display error message
end

== Search Product ==
StoreManager->>InventoryConsole: Select "Search Product"
InventoryConsole->>StoreManager: Prompt for full or partial name
StoreManager-->>InventoryConsole: nameQuery
InventoryConsole->>InventoryService: searchProducts(nameQuery)
InventoryService->>Utils: isNonEmptyText(nameQuery)
alt valid search input
  loop for each product
    InventoryService->>Utils: containsIgnoreCase(product.name, nameQuery)
  end
  InventoryService-->>InventoryConsole: matchingProducts
  InventoryConsole-->>StoreManager: Display matching products
else empty search text
  InventoryService-->>InventoryConsole: empty result / validation failure
  InventoryConsole-->>StoreManager: Display error or no matches
end

== Remove Product ==
StoreManager->>InventoryConsole: Select "Remove Product"
InventoryConsole->>StoreManager: Prompt for product ID
StoreManager-->>InventoryConsole: productId
InventoryConsole->>InventoryService: removeProduct(productId)
InventoryService->>Utils: isPositiveId(productId)
InventoryService->>InventoryService: productExists(productId)
alt valid existing product ID
  InventoryService->>InventoryService: erase Product
  InventoryService-->>InventoryConsole: removal success
  InventoryConsole->>InventoryService: getAllProducts()
  InventoryService-->>InventoryConsole: products
  InventoryConsole->>InventoryRepository: saveProducts(products)
  InventoryRepository->>InventoryJson: write updated products array
  InventoryJson-->>InventoryRepository: persisted
  InventoryRepository-->>InventoryConsole: save complete
  InventoryConsole-->>StoreManager: Display success
else invalid product ID
  InventoryService-->>InventoryConsole: removal failure
  InventoryConsole-->>StoreManager: Display error message
end

== Exit ==
StoreManager->>InventoryConsole: Select "Exit"
InventoryConsole-->>StoreManager: Terminate application
