sequenceDiagram
autonumber
actor Receptionist
participant HotelConsole
participant HotelService
participant HotelRepository
participant HotelJson as hotel.json

== System Initialization ==
HotelConsole->>HotelService: initialize(repository)
HotelService->>HotelRepository: loadRooms()
alt hotel.json exists
  HotelRepository->>HotelJson: read rooms array
  HotelJson-->>HotelRepository: room records
  HotelRepository-->>HotelService: rooms
else file missing
  HotelRepository-->>HotelService: empty room list
end
HotelService->>HotelRepository: loadReservations()
alt hotel.json exists
  HotelRepository->>HotelJson: read reservations array
  HotelJson-->>HotelRepository: reservation records
  HotelRepository-->>HotelService: reservations
else file missing
  HotelRepository-->>HotelService: empty reservation list
end
HotelService->>HotelService: determine nextReservationId
HotelService-->>HotelConsole: ready with in-memory state

== Book Room ==
Receptionist->>HotelConsole: Select "Book Room"
HotelConsole->>Receptionist: Prompt for guest name, room number, and date
Receptionist-->>HotelConsole: guestName, roomNumber, date
HotelConsole->>HotelService: bookRoom(guestName, roomNumber, date, repository)
HotelService->>HotelService: validateBookingInput(guestName, roomNumber, date)
HotelService->>HotelService: roomExists(roomNumber)
HotelService->>HotelService: isRoomAvailable(roomNumber)
alt valid input and room available
  HotelService->>HotelService: create Reservation(status = "Booked")
  HotelService->>HotelService: assign unique reservation ID
  HotelService->>HotelRepository: saveAll(rooms, reservations)
  HotelRepository->>HotelJson: write updated rooms and reservations
  HotelJson-->>HotelRepository: persisted
  HotelRepository-->>HotelService: save complete
  HotelService-->>HotelConsole: created Reservation
  HotelConsole-->>Receptionist: Display reservation ID and success
else invalid input or unavailable room
  HotelService-->>HotelConsole: booking failure
  HotelConsole-->>Receptionist: Display validation error
end

== Check-in Guest ==
Receptionist->>HotelConsole: Select "Check-in Guest"
HotelConsole->>Receptionist: Prompt for reservation ID
Receptionist-->>HotelConsole: reservationId
HotelConsole->>HotelService: checkInGuest(reservationId, repository)
HotelService->>HotelService: reservationExists(reservationId)
alt reservation exists and status is "Booked"
  HotelService->>HotelService: mark room.isAvailable = false
  HotelService->>HotelService: update reservation.status = "CheckedIn"
  HotelService->>HotelRepository: saveAll(rooms, reservations)
  HotelRepository->>HotelJson: write updated rooms and reservations
  HotelJson-->>HotelRepository: persisted
  HotelRepository-->>HotelService: save complete
  HotelService-->>HotelConsole: check-in success
  HotelConsole-->>Receptionist: Display success
else invalid reservation ID or invalid status
  HotelService-->>HotelConsole: check-in failure
  HotelConsole-->>Receptionist: Display error message
end

== Check-out Guest ==
Receptionist->>HotelConsole: Select "Check-out Guest"
HotelConsole->>Receptionist: Prompt for reservation ID
Receptionist-->>HotelConsole: reservationId
HotelConsole->>HotelService: checkOutGuest(reservationId, repository)
HotelService->>HotelService: reservationExists(reservationId)
alt reservation exists and status is "CheckedIn"
  HotelService->>HotelService: mark room.isAvailable = true
  HotelService->>HotelService: update reservation.status = "CheckedOut"
  HotelService->>HotelRepository: saveAll(rooms, reservations)
  HotelRepository->>HotelJson: write updated rooms and reservations
  HotelJson-->>HotelRepository: persisted
  HotelRepository-->>HotelService: save complete
  HotelService-->>HotelConsole: check-out success
  HotelConsole-->>Receptionist: Display success
else invalid reservation ID or invalid status
  HotelService-->>HotelConsole: check-out failure
  HotelConsole-->>Receptionist: Display error message
end

== Cancel Reservation ==
Receptionist->>HotelConsole: Select "Cancel Reservation"
HotelConsole->>Receptionist: Prompt for reservation ID
Receptionist-->>HotelConsole: reservationId
HotelConsole->>HotelService: cancelReservation(reservationId, repository)
HotelService->>HotelService: reservationExists(reservationId)
alt reservation exists and not finalized
  HotelService->>HotelService: update reservation.status = "Canceled"
  HotelService->>HotelService: keep room available when reservation is not checked in
  HotelService->>HotelRepository: saveAll(rooms, reservations)
  HotelRepository->>HotelJson: write updated rooms and reservations
  HotelJson-->>HotelRepository: persisted
  HotelRepository-->>HotelService: save complete
  HotelService-->>HotelConsole: cancellation success
  HotelConsole-->>Receptionist: Display success
else invalid reservation ID
  HotelService-->>HotelConsole: cancellation failure
  HotelConsole-->>Receptionist: Display error message
end

== View Room Availability ==
Receptionist->>HotelConsole: Select "View Room Availability"
HotelConsole->>HotelService: getRooms()
HotelService-->>HotelConsole: rooms with roomNumber and isAvailable
HotelConsole-->>Receptionist: Display all rooms and availability status

== Exit ==
Receptionist->>HotelConsole: Select "Exit"
HotelConsole-->>Receptionist: End application
